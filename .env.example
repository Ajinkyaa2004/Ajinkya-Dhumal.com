# Copy to .env for local dev, or set in Vercel → Project → Settings → Environment Variables.
#
# Powers the "Ask Ajinkya" AI assistant (api/chat.js), which uses Groq.
# Without it, the assistant returns a friendly fallback instead of live answers.
# Get a key at https://console.groq.com (API Keys → Create API Key).
GROQ_API_KEY=
