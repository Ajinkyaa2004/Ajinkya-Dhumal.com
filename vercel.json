{
  "redirects": [
    { "source": "/:path*", "has": [{ "type": "host", "value": "www.ajinkyadhumal.com" }], "destination": "https://ajinkyadhumal.com/:path*", "permanent": true },
    { "source": "/:path*", "has": [{ "type": "host", "value": "itsajinkya.vercel.app" }], "destination": "https://ajinkyadhumal.com/:path*", "permanent": true }
  ],
  "rewrites": [{ "source": "/((?!api/).*)", "destination": "/index.html" }],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()" }
      ]
    }
  ]
}
